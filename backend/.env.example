# Copy this file to backend/.env and fill in values as needed.

# OpenRouteService API key. If set, real road routing (driving-hgv profile)
# is used. If empty/omitted, the app falls back to a haversine + 55 mph mock
# route so the demo still works fully offline.
ORS_API_KEY=

# Nominatim requires a descriptive User-Agent per its usage policy.
NOMINATIM_USER_AGENT=trucklog-hos-planner/1.0 (you@example.com)

# Django
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-insecure-key-change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS (Vite dev server origins). Set CORS_ALLOW_ALL_ORIGINS=1 to allow all.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL_ORIGINS=0
