# Optional: override the API base URL. By default the app uses a relative
# "/api" path, which the Vite dev server proxies to http://localhost:8000.
# For a deployed frontend talking to a remote backend, set e.g.:
# VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=

# Optional: target the dev proxy at a different backend host.
VITE_API_TARGET=http://localhost:8000
